{
  "embeddingProvider": "custom",
  "customProvider": {
    "baseUrl": "http://127.0.0.1:11434/v1",
    "model": "mock-embedding-model",
    "dimensions": 8,
    "timeoutMs": 10000
  },
  "indexing": {
