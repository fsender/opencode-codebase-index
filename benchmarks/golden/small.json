        "filePath": "src/tools/index.ts",
        "symbol": "codebase_search"
      }
    },
    {
      "id": "sim-find-similar",
      "query": "find similar code feature and duplicates",
      "queryType": "similarity",
      "expected": {
        "filePath": "src/tools/index.ts",
        "symbol": "find_similar"
      }
    },
    {
      "id": "kw-search-config-knobs",
      "query": "fusionStrategy hybridWeight rrfK rerankTopN",
      "queryType": "keyword-heavy",
      "expected": {
        "acceptableFiles": [
          "src/config/schema.ts",
          "src/indexer/index.ts"
        ]
      }
    }
  ]
